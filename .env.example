# ============================================================
#  ร้าน 100 บาท — Marketing AI Platform
#  ตัวอย่างตัวแปรสภาพแวดล้อม (Environment Variables Example)
#  คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าให้ถูกต้อง:  cp .env.example .env
# ============================================================

# ------------------------------------------------------------
#  GENERAL
# ------------------------------------------------------------
NODE_ENV=development                 # development | production | test
APP_NAME="100 Baht Shop Marketing AI"
DEFAULT_LOCALE=th                    # ภาษาเริ่มต้น (th) — รองรับ en ในอนาคต
SUPPORTED_LOCALES=th,en
TZ=Asia/Bangkok

# ------------------------------------------------------------
#  FRONTEND (Next.js)
# ------------------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_DEFAULT_LOCALE=th

# ------------------------------------------------------------
#  BACKEND (NestJS)
# ------------------------------------------------------------
BACKEND_PORT=4000
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------
#  DATABASE (MySQL)
# ------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=mkttools
DB_PASSWORD=change_me
DB_DATABASE=rt_mkttools
DB_CONNECTION_LIMIT=10
DB_LOGGING=false

# ------------------------------------------------------------
#  AUTH (JWT)
# ------------------------------------------------------------
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ------------------------------------------------------------
#  AI (OpenAI)
# ------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7
AI_MONTHLY_TOKEN_LIMIT=1000000        # โควต้า token ต่อเดือน (per tenant default)

# ------------------------------------------------------------
#  REALTIME (Socket.io)
# ------------------------------------------------------------
SOCKET_PATH=/socket.io
SOCKET_CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------
# ERP integration (ChangSiam webservice — read-only)
# ------------------------------------------------------------
ERP_API_BASE_URL=https://dev.changsiamthailand.com/webservice/api.php
ERP_API_KEY=
ERP_API_TIMEOUT_MS=20000

# ------------------------------------------------------------
#  STORAGE / UPLOADS
# ------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# ------------------------------------------------------------
#  EMAIL (optional - notifications / password reset)
# ------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ร้าน 100 บาท <no-reply@example.com>"

# ------------------------------------------------------------
#  RATE LIMITING
# ------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120

# ------------------------------------------------------------
#  DEPLOY / PM2 (production)
# ------------------------------------------------------------
PM2_INSTANCES=max
LOG_LEVEL=info
