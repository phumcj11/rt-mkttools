# ============================================================
#  ร้าน 100 บาท — ตัวอย่าง .env สำหรับ Production (rt.k-mkt.com)
#  บน VPS: คัดลอกไปเป็น /var/www/rt_mkttools/.env แล้วแก้ค่า secret จริง
#  ⚠️ ห้าม commit ไฟล์ .env จริงเข้า git
# ============================================================

NODE_ENV=production
APP_NAME="100 Baht Shop Marketing AI"
DEFAULT_LOCALE=th
SUPPORTED_LOCALES=th,en
TZ=Asia/Bangkok

# ---- Frontend (Next.js) ----
FRONTEND_PORT=3000
NEXT_PUBLIC_APP_URL=https://rt.k-mkt.com
NEXT_PUBLIC_API_URL=https://rt.k-mkt.com/api
NEXT_PUBLIC_SOCKET_URL=https://rt.k-mkt.com
NEXT_PUBLIC_DEFAULT_LOCALE=th

# ---- Backend (NestJS) ----
BACKEND_PORT=4000
API_PREFIX=api
# URL สำหรับ OAuth callback (ถ้าไม่ตั้ง จะ derive จาก CORS_ORIGINS + API_PREFIX)
# API_BASE_URL=https://rt.k-mkt.com/api
# FRONTEND_URL=https://rt.k-mkt.com
CORS_ORIGINS=https://rt.k-mkt.com

# ---- Database (MySQL) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=mkttools
DB_PASSWORD=__CHANGE_ME__
DB_DATABASE=rt_mkttools
DB_CONNECTION_LIMIT=10
DB_LOGGING=false
DB_SYNCHRONIZE=false

# ---- Auth (JWT) ---- (สร้างด้วย: openssl rand -hex 32)
JWT_ACCESS_SECRET=__CHANGE_ME__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=__CHANGE_ME__
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# ---- AI (OpenAI) ----
OPENAI_API_KEY=__CHANGE_ME__
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1024
OPENAI_TEMPERATURE=0.7

# ---- Realtime ----
SOCKET_PATH=/socket.io
SOCKET_CORS_ORIGINS=https://rt.k-mkt.com

# ---- Misc ----
LOG_LEVEL=info
PM2_INSTANCES=max
